# Copy to .env.local and fill in. Never commit .env.local.

# --- Database -----------------------------------------------------------
# Neon/Supabase/RDS all work. Append ?sslmode=require for hosted providers.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Creator auth (Google SSO) ------------------------------------------
# Google Cloud Console > APIs & Services > Credentials > OAuth client ID
# (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (dev)
#   https://YOUR_DOMAIN/api/auth/callback/google     (prod)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Generate with: npx auth secret
AUTH_SECRET=""

# Comma-separated. Only these domains may sign in and create links.
# If unset, NOBODY can sign in — this fails closed on purpose.
ALLOWED_EMAIL_DOMAINS="jumpapp.com"

# --- OTP ----------------------------------------------------------------
# Secret pepper mixed into OTP hashes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this invalidates all outstanding codes.
OTP_PEPPER=""

# --- Email --------------------------------------------------------------
# https://resend.com/api-keys. If unset, codes print to the server console
# so you can test the flow locally without an email provider.
RESEND_API_KEY=""
MAIL_FROM="Secret Share <secrets@yourdomain.com>"

# --- Deployment ---------------------------------------------------------
# Set to 1 ONLY behind a proxy that overwrites x-forwarded-for (Vercel,
# Cloudflare, an ALB you control). On a bare server, clients can forge it.
TRUST_PROXY="0"
